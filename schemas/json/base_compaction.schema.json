{
  "$defs": {
    "FrictionCategory": {
      "description": "Categories of friction surfaced by the compactor / failure miner.",
      "enum": [
        "loop",
        "tool_error",
        "abandon",
        "retry",
        "deadend"
      ],
      "title": "FrictionCategory",
      "type": "string"
    },
    "FrictionPoint": {
      "additionalProperties": false,
      "description": "One friction event, evidenced by specific turns.",
      "properties": {
        "category": {
          "$ref": "#/$defs/FrictionCategory"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "turn_refs": {
          "description": "Turn ids that evidence this friction",
          "items": {
            "type": "string"
          },
          "title": "Turn Refs",
          "type": "array"
        }
      },
      "required": [
        "category",
        "description"
      ],
      "title": "FrictionPoint",
      "type": "object"
    },
    "Outcome": {
      "description": "Terminal outcome of a session/compaction.",
      "enum": [
        "success",
        "partial",
        "abandoned"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "Surface": {
      "description": "The tool surface a session was captured from.",
      "enum": [
        "claude_code",
        "codex",
        "cursor"
      ],
      "title": "Surface",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Typed digest of a single session (surface-agnostic).",
  "properties": {
    "action_triggers": {
      "items": {
        "type": "string"
      },
      "title": "Action Triggers",
      "type": "array"
    },
    "actor": {
      "title": "Actor",
      "type": "string"
    },
    "approach": {
      "description": "How they went about it",
      "title": "Approach",
      "type": "string"
    },
    "artifacts": {
      "description": "Things produced",
      "items": {
        "type": "string"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "cache_read_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Read Tokens"
    },
    "cache_write_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Write Tokens"
    },
    "call_cost_usd": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Call Cost Usd"
    },
    "created_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "duration_seconds": {
      "title": "Duration Seconds",
      "type": "number"
    },
    "ended_at": {
      "format": "date-time",
      "title": "Ended At",
      "type": "string"
    },
    "est_cost_usd": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "API list-price equivalent in USD \u2014 NOT subscription spend. Dominated by cache-reads on long sessions; prefer total_tokens for magnitude.",
      "title": "Est Cost Usd"
    },
    "friction_points": {
      "items": {
        "$ref": "#/$defs/FrictionPoint"
      },
      "title": "Friction Points",
      "type": "array"
    },
    "hold": {
      "default": false,
      "title": "Hold",
      "type": "boolean"
    },
    "id": {
      "description": "Stable compaction id",
      "title": "Id",
      "type": "string"
    },
    "input_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Tokens"
    },
    "kind": {
      "const": "base",
      "default": "base",
      "title": "Kind",
      "type": "string"
    },
    "native_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Native Summary"
    },
    "outcome": {
      "$ref": "#/$defs/Outcome"
    },
    "output_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Tokens"
    },
    "project": {
      "title": "Project",
      "type": "string"
    },
    "prompt_version": {
      "default": "v0",
      "description": "Compaction prompt template version",
      "title": "Prompt Version",
      "type": "string"
    },
    "released": {
      "default": false,
      "title": "Released",
      "type": "boolean"
    },
    "released_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Released At"
    },
    "reusable_pattern": {
      "default": false,
      "title": "Reusable Pattern",
      "type": "boolean"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "source": {
      "default": "pending",
      "enum": [
        "pending",
        "full",
        "claude_summary"
      ],
      "title": "Source",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "surface": {
      "$ref": "#/$defs/Surface"
    },
    "task_intent": {
      "description": "What the engineer set out to do",
      "title": "Task Intent",
      "type": "string"
    },
    "tier_used": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Dominant model tier",
      "title": "Tier Used"
    },
    "total_tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Total tokens (input + output + cache write + cache read) for the session",
      "title": "Total Tokens"
    }
  },
  "required": [
    "id",
    "session_id",
    "actor",
    "surface",
    "project",
    "started_at",
    "ended_at",
    "duration_seconds",
    "task_intent",
    "approach",
    "outcome"
  ],
  "title": "BaseCompaction",
  "type": "object"
}
