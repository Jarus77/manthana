# Manthana server configuration — copy to .env and fill in.
#
#   cp .env.example .env        # then edit .env (it is gitignored)
#   set -a; source .env; set +a # load into the shell
#   uv run manthana-server serve --port 8000
#
# Or use the helper that does the load+run for you:
#   ./scripts/serve.sh
#
# Full reference with defaults and rationale: docs/reference/environment.md
#
# NEVER put secrets on the command line (they leak into shell history, process
# lists, and logs). Keep them here, in .env, which is gitignored.
#
# Booleans accept "1", "true", or "yes"; anything else (including unset) is false.

# ── Secrets (required in production; the code rejects empty values) ──────────
# Bearer-token signing secret for agent→server sync (>= 32 bytes recommended).
# Rotating this invalidates EVERY issued agent, founder, and engineer token.
MANTHANA_SERVER_JWT_SECRET="change-me-to-a-long-random-string-min-32-bytes"
# Admin token: gates the founder console (/ui) + admin/founder API endpoints.
MANTHANA_SERVER_ADMIN_TOKEN="change-me-admin-token"

# ── Storage ─────────────────────────────────────────────────────────────────
# Postgres (prod) or sqlite:///./manthana-server.db (dev). The docker-compose
# Postgres is published on host port 5433.
MANTHANA_SERVER_DB_URL="postgresql+psycopg://manthana:manthana@localhost:5433/manthana"
# Object store for raw-transcript release: "memory" (dev) | "s3" (prod).
# NOTE: docker-compose overrides these for the in-cluster server (S3 -> MinIO).
# "memory" LOSES every raw transcript on restart — never pair it with Postgres.
MANTHANA_SERVER_OBJECT_STORE="memory"
# MANTHANA_SERVER_S3_BUCKET="manthana-raw"               # required when OBJECT_STORE=s3
# MANTHANA_SERVER_S3_ENDPOINT_URL="http://localhost:9000" # set for MinIO / non-AWS S3
# MANTHANA_SERVER_S3_ACCESS_KEY="manthana"                # else boto3's default cred chain
# MANTHANA_SERVER_S3_SECRET_KEY="manthana-secret"
# Hard ceiling on ONE uploaded raw transcript (bytes, default 25 MB). Bounds
# memory on the privileged founder drill path.
MANTHANA_SERVER_MAX_RAW_BYTES="25000000"
# Whole-request Content-Length ceiling (bytes, default 30 MB). Deliberately above
# MAX_RAW_BYTES so the raw endpoint's own cap stays the binding limit on its path.
MANTHANA_SERVER_MAX_REQUEST_BYTES="30000000"

# ── Privacy ─────────────────────────────────────────────────────────────────
# k-anonymity floor for founder aggregates (>= 1; production default is 4).
# Set to 1 ONLY for a single-contributor local install, where there is nobody to
# de-identify from and the floor would only hide your own data from you.
MANTHANA_SERVER_K_ANON="4"
# Default posture for orgs with no explicit override (per-org: PUT
# /v1/admin/orgs/{id}/privacy). "k_anon" = de-identified, floor-gated aggregates.
# "open" = the founder sees named, per-individual results. Personal-mode sessions
# never sync in EITHER mode, and named queries are audited in both.
MANTHANA_SERVER_PRIVACY_MODE="k_anon"

# ── Model provider (founder narrative, digest, and every server-side pass) ──
# "mock"       deterministic, offline, returns {} / "insufficient data" (default)
# "anthropic"  the API — needs ANTHROPIC_API_KEY and the "manthana-server[llm]" extra
# "claude_cli" bring-your-own-model: shells out to a Claude CLI installed AND
#              logged in as the user running the server, so a self-hoster spends
#              the subscription they already pay for. Works on a laptop; does NOT
#              work in the container images (no binary, no logged-in $HOME). If
#              the binary is missing the server logs loudly and falls back to the
#              mock — it never crashes.
MANTHANA_SERVER_LLM="mock"
# Which binary the claude_cli provider invokes.
MANTHANA_SERVER_CLAUDE_CLI="claude"
# Model id for the anthropic provider. Strong, cost-sensible default for grounded
# summarization; override to claude-opus-4-8 for the most capable model.
MANTHANA_SERVER_LLM_MODEL="claude-sonnet-4-6"
# Max output tokens for the narrative (1..100000).
MANTHANA_SERVER_LLM_MAX_TOKENS="1024"
# Anthropic API key — REQUIRED when MANTHANA_SERVER_LLM=anthropic. The org
# provisions this; the SDK reads ANTHROPIC_API_KEY from the environment.
# ANTHROPIC_API_KEY="sk-ant-..."
# Server-wide DEFAULT monthly AI budget per org, USD. 0 = unlimited (usage is
# still recorded) — the right value for a self-hoster paying their own bill.
# Hosted multi-tenant operators should set a real number; `onboard-org` also
# writes an explicit $100/month per-org override for each new customer.
MANTHANA_SERVER_LLM_MONTHLY_CAP_USD="0"

# ── Console / wiki ──────────────────────────────────────────────────────────
# Public base URL of THIS deployment, no trailing slash. Used only to print the
# shareable wiki-login link a founder sends a new engineer — never for routing
# or auth, so a wrong value yields a bad link, not a security hole.
MANTHANA_SERVER_PUBLIC_URL="https://api.example.com"
# Mark console cookies Secure (HTTPS-only). MUST be "1" on any public TLS
# deployment; leave unset for local HTTP development or logins will not stick.
MANTHANA_SERVER_COOKIE_SECURE="1"
# Retire the legacy server-rendered wiki: its pages 303 to the Next.js client in
# web/ instead of rendering HTML. The founder console is unaffected.
#
# Only turn this on where the client is actually being served in front of this
# process (the `web` service in docker-compose, routed by deploy/Caddyfile).
# The redirect targets ("/", "/people/...") belong to the client, so enabling it
# without one replaces a working wiki with a 404. See docs/self-hosting/web-client.md.
MANTHANA_SERVER_RETIRE_HTML_WIKI="0"

# ── Founder MCP gateway ─────────────────────────────────────────────────────
# Mounts the founder's Claude Code ↔ org data bridge. OFF by default: the
# transport mount has lifespan/session-manager wiring that must be verified with
# a live MCP client before it can risk the main app.
MANTHANA_SERVER_ENABLE_FOUNDER_MCP="0"
# Comma-separated Host allowlist for the MCP endpoint's DNS-rebinding check.
# MUST include the public domain behind your load balancer. "*" disables it.
MANTHANA_SERVER_MCP_ALLOWED_HOSTS="localhost,127.0.0.1,testserver"

# ── Digest enrichment (agents send deterministic digests; this fills them in) ─
# Agents emit source="pending" digests that spend no tokens locally; this pass
# fills the qualitative fields on the operator's model. OFF by default because
# enabling it starts a background loop that spends real money — that must be an
# explicit operator decision, never a surprise. EVERYTHING downstream (the wiki,
# consolidation, project articles) depends on this pass.
MANTHANA_SERVER_ENABLE_ENRICHMENT="0"
# Cheap model: this is bulk structured summarization, not reasoning.
MANTHANA_SERVER_ENRICH_MODEL="claude-haiku-4-5"
MANTHANA_SERVER_ENRICH_MAX_TOKENS="2048"
# Seconds between background passes.
MANTHANA_SERVER_ENRICH_INTERVAL="300"
# Per-org ceiling for one pass, so one org's backlog cannot starve other tenants.
MANTHANA_SERVER_ENRICH_BATCH_PER_ORG="25"
# Whole-pass ceiling across all orgs.
MANTHANA_SERVER_ENRICH_MAX_BATCH="200"
# A pending digest whose raw transcript never arrives WAITS rather than burning a
# model call, and is abandoned after this many attempts or once it is this old.
# POST /v1/admin/enrichment/retry un-abandons the ones whose raw has since landed.
MANTHANA_SERVER_ENRICH_MAX_ATTEMPTS="5"
MANTHANA_SERVER_ENRICH_MAX_AGE_DAYS="7"

# ── Org wiki: knowledge consolidation ───────────────────────────────────────
# Turns enriched session digests into typed wiki notes (decisions, conventions,
# gotchas, benchmarks) via one cheap model call per session. OFF by default
# because it spends money in a background loop. Requires enrichment to be on —
# consolidation only ever reads digests that enrichment has already filled in.
MANTHANA_SERVER_ENABLE_CONSOLIDATION="0"
# Cheap model for bulk adjudication (same tier logic as enrichment).
MANTHANA_SERVER_CONSOLIDATE_MODEL="claude-haiku-4-5"
MANTHANA_SERVER_CONSOLIDATE_MAX_TOKENS="2048"
# Seconds between background passes; per-org and whole-pass batch ceilings.
MANTHANA_SERVER_CONSOLIDATE_INTERVAL="300"
MANTHANA_SERVER_CONSOLIDATE_BATCH_PER_ORG="25"
MANTHANA_SERVER_CONSOLIDATE_MAX_BATCH="200"
# Candidate retrieval: how many live notes one adjudication sees (top-k by
# cosine, plus entity-overlap hits), and how many notes that retrieval scans.
MANTHANA_SERVER_CONSOLIDATE_TOP_K="8"
MANTHANA_SERVER_CONSOLIDATE_NOTE_SCAN="500"
# A compaction whose adjudication keeps failing is abandoned, never retried.
MANTHANA_SERVER_CONSOLIDATE_MAX_ATTEMPTS="3"

# ── Org wiki: project descriptions ──────────────────────────────────────────
# Writes one `project_overview` note per project describing what the project IS.
# A project slug is only ever the git repo directory name, so without this the
# wiki can say nothing about a project beyond which org it belongs to. OFF by
# default because it spends money in a background loop. Cost is bounded by a
# hash of each project's contributing sessions: it regenerates when the WORK
# changes, not on a timer, and never re-describes a project a human has edited.
MANTHANA_SERVER_ENABLE_PROJECT_OVERVIEW="0"
# Seconds between passes — a project description changes over weeks, not minutes.
MANTHANA_SERVER_OVERVIEW_INTERVAL="3600"
# Whole-pass ceiling across all orgs; sessions fed into one call.
MANTHANA_SERVER_OVERVIEW_MAX_PER_PASS="10"
MANTHANA_SERVER_OVERVIEW_SESSION_LIMIT="40"
# A one-session project still deserves "what this is" — that is exactly the case
# where a reader has least context.
MANTHANA_SERVER_OVERVIEW_MIN_SESSIONS="1"
MANTHANA_SERVER_OVERVIEW_MAX_ATTEMPTS="3"

# ── Org skill mining bounds ─────────────────────────────────────────────────
# Mining is O(n^2) in clustering plus one model call per cluster, so an unbounded
# run over a large org holds the request open until the gateway times out. Both
# bounds are REPORTED to the founder: a run that hit one says so, rather than
# silently covering less than the founder assumes.
MANTHANA_SERVER_MINE_WINDOW_DAYS="90"
MANTHANA_SERVER_MINE_MAX_ITEMS="1000"
